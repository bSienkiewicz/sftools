{
  "version": 2,
  "date": "2026-05-19",
  "prefixOverrides": {
    "hm": "H&M",
    "pierceab": "PierceAB",
    "jlp": "JLP",
    "cycleon": "Cycleon",
    "michaelkors": "MICHAELKORS",
    "mpm4dm01": "MPM4DM01",
    "mpm4dm02": "MPM4DM02",
    "mpm4dm03": "MPM4DM03",
    "mpm4dm04": "MPM4DM04",
    "mpm4dmasos": "MPM4DMASOS"
  },
  "baseFormDefaults": [
    { "fieldLabel": "Team", "value": "Support" },
    { "fieldLabel": "Severity", "value": "3" },
    { "fieldLabel": "Carrier module", "value": "Unknown" }
  ],
  "incidentLookupDefaults": [
    {
      "fieldLabel": "Account Name",
      "searchText": "Metapack PL",
      "optionContains": "Metapack Internal PL Cases"
    },
    {
      "fieldLabel": "Contact Name",
      "searchText": "Metapack PL",
      "optionContains": "Metapack PL Internal Cases"
    }
  ],
  "alertTypes": [
    {
      "id": "failed-pipeline",
      "name": "Failed Pipeline",
      "classify": { "rawRegex": "Failed Pipeline:", "rawFlags": "i" },
      "extract": {
        "pipelineNameFromRaw": true,
        "prefixFixed": "DM",
        "subject": "DM|{displayName}|Failed Pipeline for {pipelineName}"
      },
      "formOverrides": [{ "fieldLabel": "Type", "value": "System Setup" }]
    },
    {
      "id": "mpm-no-events",
      "name": "MPM NoEventsFound",
      "classify": {
        "rawMatchAll": [
          { "pattern": "NoEventsFound", "flags": "i" },
          { "pattern": "(\\btrep\\b|microservices)", "flags": "i" }
        ]
      },
      "extract": {
        "trepCarrierFromRaw": true,
        "body": "NoEventsFound for carrier {carrier}",
        "prefix": "fixed",
        "prefixFixed": "MP ALL",
        "subject": "MP ALL|PD|NoEventsFound for carrier {carrier}"
      },
      "formOverrides": [{ "fieldLabel": "Type", "value": "Tracking" }]
    },
    {
      "id": "mpm-not-valid-filename",
      "name": "MPM NotValidFileName",
      "classify": {
        "rawMatchAll": [
          { "pattern": "NotValidFileName", "flags": "i" },
          { "pattern": "(\\btrep\\b|microservices)", "flags": "i" }
        ]
      },
      "extract": {
        "trepCarrierFromRaw": true,
        "body": "NotValidFileName for {carrier}",
        "prefix": "fixed",
        "prefixFixed": "MP ALL",
        "subject": "MP ALL|PD|NotValidFileName for {carrier}"
      },
      "formOverrides": [{ "fieldLabel": "Type", "value": "Tracking" }]
    },
    {
      "id": "dm-failed-transfer",
      "name": "DM Failed Transfer",
      "classify": {
        "rawMatchAll": [
          { "pattern": "DM-SCHEDULER" },
          { "pattern": "Failed Transfer", "flags": "i" }
        ]
      },
      "extract": {
        "body": "Failed Transfer",
        "prefixFromRawMatch": { "pattern": "DM-SCHEDULER-DM(\\d)", "flags": "i", "template": "DM{n}", "fallback": "DM" },
        "subject": "{prefix}|<Customer>|PD|Failed Transfer for <Module>"
      },
      "formOverrides": [
        { "fieldLabel": "Type", "value": "Manifesting" },
        { "fieldLabel": "Carrier module", "value": "Single" }
      ]
    },
    {
      "id": "mpm-failed-transfer",
      "name": "MPM Failed Transfer",
      "classify": {
        "requiresBodyForMatch": true,
        "bodyKeywords": ["Failed Transfer", "failed transfer", "Edi Failed Transfer"]
      },
      "extract": {
        "transferCodeFromRaw": true,
        "body": "Failed transfer for {code}",
        "bodyFallback": "Failed transfer",
        "prefix": "context"
      },
      "subjectFormat": "{prefix}|PD|{body}",
      "formOverrides": [
        { "fieldLabel": "Type", "value": "Manifesting" },
        { "fieldLabel": "Carrier module", "value": "Single" }
      ]
    },
    {
      "id": "dm-missing-route-codes",
      "name": "DM Missing Route Codes",
      "classify": {
        "requiresPrefix": true,
        "prefixRegex": "^DM",
        "requiresBodyForMatch": true,
        "bodyKeywords": ["E15001", "Missing route code"]
      },
      "extract": {
        "body": ["stripSeverity", "stripMidPolicyFragments", "stripLeadingPolicyIds", "stripDmBodyPrefix"],
        "prefix": "context"
      },
      "subjectFormat": "{prefix}|PD|{body}",
      "formOverrides": [{ "fieldLabel": "Type", "value": "System Setup" }]
    },
    {
      "id": "dm-database-errors",
      "name": "DM Database Errors",
      "classify": {
        "rawRegex": "DM-UX",
        "rawFlags": "i",
        "requiresBodyForMatch": true,
        "bodyKeywords": ["Database errors"]
      },
      "extract": {
        "body": ["stripSeverity"],
        "bodyReplace": [{ "pattern": "\\s-\\sDM\\s", "flags": "i", "replacement": " - " }],
        "prefix": "fixed",
        "prefixFixed": "DM"
      },
      "subjectFormat": "{prefix}|PD|{body}",
      "formOverrides": [{ "fieldLabel": "Type", "value": "System Performance" }]
    },
    {
      "id": "dm-avg-response-time",
      "name": "DM AVG Response Time",
      "classify": {
        "rawRegex": "^PRD\\s+DM-",
        "rawFlags": "i",
        "requiresBodyForMatch": true,
        "bodyKeywords": ["AVG response time"]
      },
      "extract": {
        "body": ["stripSeverity", "stripMidPolicyFragments", "stripLeadingPolicyIds"],
        "prefixFromBodyMatch": { "pattern": "\\b(mpm4dm\\d+)\\b", "flags": "i", "uppercase": true, "fallback": "DM" }
      },
      "subjectFormat": "{prefix}|PD|{body}",
      "formOverrides": [{ "fieldLabel": "Type", "value": "System Performance" }]
    },
    {
      "id": "dm-web-transaction",
      "name": "DM Web Transaction",
      "classify": {
        "requiresPrefix": true,
        "prefixRegex": "^DM",
        "requiresBodyForMatch": true,
        "bodyKeywords": ["High Web Transaction Time", "Web Transaction Time"]
      },
      "extract": { "body": "normalizeBodyDefault", "prefix": "fixed", "prefixFixed": "DM" },
      "subjectFormat": "{prefix}|PD|{body}",
      "formOverrides": [{ "fieldLabel": "Type", "value": "System Performance" }]
    },
    {
      "id": "mpm-error90",
      "name": "MPM Error90",
      "classify": {
        "requiresPrefix": true,
        "prefixRegex": "^[A-Z]",
        "requiresBodyForMatch": true,
        "bodyKeywords": ["Error rate above 90%", "90% of requests"]
      },
      "extract": { "body": "normalizeBodyDefault", "prefix": "context" },
      "subjectFormat": "{prefix}|PD|{body}",
      "formOverrides": [{ "fieldLabel": "Type", "value": "System Performance" }]
    },
    {
      "id": "hm-print-duration",
      "name": "HM PrintDuration",
      "classify": {
        "requiresPrefix": true,
        "prefixRegex": "^Hm$",
        "prefixFlags": "i",
        "requiresBodyForMatch": true,
        "bodyKeywords": ["Print duration"]
      },
      "extract": { "body": "normalizeBodyDefault", "prefix": "context" },
      "subjectFormat": "{prefix}|PD|{body}",
      "formOverrides": [{ "fieldLabel": "Type", "value": "System Performance" }]
    },
    {
      "id": "dm-duration",
      "name": "DM Duration (System Performance)",
      "classify": {
        "requiresPrefix": true,
        "prefixRegex": "^DM\\d+$",
        "requiresBodyForMatch": true,
        "bodyKeywords": ["Average Duration"]
      },
      "extract": {
        "body": "normalizeBodyDefault",
        "bodyReplace": [{ "pattern": "^Allocation\\s+", "flags": "i", "replacement": "" }],
        "prefix": "context"
      },
      "subjectFormat": "{prefix}|PD|{body}",
      "formOverrides": [{ "fieldLabel": "Type", "value": "System Performance" }]
    },
    {
      "id": "dm-allocation-customer-error-percentage",
      "name": "DM Allocation Customer (Error Percentage)",
      "classify": {
        "rawRegex": "DM-CARRIERS-DMA",
        "rawFlags": "i",
        "requiresBodyForMatch": true,
        "bodyKeywords": ["Error Percentage", "Allocation"]
      },
      "extract": {
        "body": "normalizeBodyDefault",
        "prefixFromBodyMatch": {
          "pattern": "Allocation\\s+([A-Za-z0-9]+)\\s+<",
          "flags": "i",
          "uppercase": true
        }
      },
      "subjectFormat": "DM|{prefix}|{body}",
      "formOverrides": [{ "fieldLabel": "Type", "value": "Allocation" }]
    },
    {
      "id": "dm-allocation-error-percentage",
      "name": "DM Allocation (Error Percentage)",
      "classify": {
        "requiresPrefix": true,
        "prefixRegex": "^DM\\d+$",
        "requiresBodyForMatch": true,
        "bodyKeywords": ["Error Percentage"]
      },
      "extract": { "body": "normalizeBodyDefault", "prefix": "context" },
      "subjectFormat": "{prefix}|PD|{body}",
      "formOverrides": [{ "fieldLabel": "Type", "value": "Allocation" }]
    },
    {
      "id": "dm-allocation-error-rate",
      "name": "DM Allocation (Error Rate)",
      "classify": {
        "requiresPrefix": true,
        "prefixRegex": "^DM ALL$"
      },
      "extract": { "body": "normalizeBodyDefault", "prefix": "fixed", "prefixFixed": "DM ALL" },
      "subjectFormat": "{prefix}|PD|{body}",
      "formOverrides": [{ "fieldLabel": "Type", "value": "Allocation" }]
    },
    {
      "id": "mpm-duration",
      "name": "MPM Duration (System Performance)",
      "classify": {
        "requiresPrefix": true,
        "prefixNotRegex": "^DM",
        "requiresBodyForMatch": true,
        "bodyKeywords": ["PrintParcel Duration", "Increased PrintParcel Duration"]
      },
      "extract": { "body": "normalizeBodyDefault", "prefix": "context" },
      "subjectFormat": "{prefix}|PD|{body}",
      "formOverrides": [{ "fieldLabel": "Type", "value": "System Performance" }]
    },
    {
      "id": "mpm-allocation-error-rate",
      "name": "MPM Allocation (Error Rate)",
      "classify": {
        "requiresPrefix": true,
        "prefixNotRegex": "^DM",
        "requiresBodyForMatch": true,
        "bodyKeywords": ["Increased Error Rate"]
      },
      "extract": { "body": "normalizeBodyDefault", "prefix": "context" },
      "subjectFormat": "{prefix}|PD|{body}",
      "formOverrides": [{ "fieldLabel": "Type", "value": "Allocation" }]
    },
    {
      "id": "mpm-generic",
      "name": "MPM Generic",
      "classify": {
        "requiresPrefix": true,
        "prefixNotRegex": "^DM"
      },
      "extract": {
        "body": ["stripSeverity", "stripTagChain"],
        "prefix": "context"
      },
      "subjectFormat": "{prefix}|PD|{body}",
      "formOverrides": [{ "fieldLabel": "Type", "value": "System Performance" }]
    }
  ]
}
